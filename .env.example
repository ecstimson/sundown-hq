# ─── Required: Supabase (frontend) ───
# These are exposed to the browser via Vite's VITE_ prefix — safe for anon key.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ─── Required: Supabase (scripts only) ───
# Service role key is NEVER exposed to the browser. Used only by scripts/import-animals.ts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Optional: Gemini AI ───
# Used by future AI features. If needed, access via a server-side proxy, NOT the client bundle.
# GEMINI_API_KEY="your-gemini-api-key"

# ─── Optional: Slack Integration ───
# Incoming Webhook URL for manual connection testing and future alert notifications.
# Setup: https://api.slack.com/apps → Your App → Incoming Webhooks → Add New Webhook to Workspace
# Once added, a "Send Test Message" button will appear in Admin → Integrations.
# VITE_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
